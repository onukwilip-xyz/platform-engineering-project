        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "sum by (namespace, pod, container) (\n  rate(container_cpu_cfs_throttled_periods_total{\n    namespace=~\"${namespace:regex}\",\n    container!=\"\",\n    container!=\"POD\"\n  }[1m])\n)\n/\nsum by (namespace, pod, container) (\n  rate(container_cpu_cfs_periods_total{\n    namespace=~\"${namespace:regex}\",\n    container!=\"\",\n    container!=\"POD\"\n  }[1m])\n)\n* 100",
          "legendFormat": "Container: {{container}}, Namespace: {{namespace}}, Pod: {{pod}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "CPU Throttling Rate (% of periods throttled)",
      "transparent": true,
      "type": "timeseries"
    },
